# Lamarca local development env vars.
# Copy to .env and fill in real values. .env is gitignored.

# ── Database ──────────────────────────────────────────────
# Neon pooled connection string (Connection Details → Pooled connection)
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# ── Django ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
# True for local dev, False on Vercel
DEBUG=True

# ── Google Sign-In ────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Add http://localhost:8000 and http://127.0.0.1:8000 to Authorized JavaScript origins
GOOGLE_CLIENT_ID=

# ── Gemini (blog generation) ──────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Supadata (YouTube transcripts) ────────────────────────
# Get from: https://supadata.ai
SUPADATA_API_KEY=

# ── Stripe (credit packs, Test Mode) ──────────────────────
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_

# Get from: https://dashboard.stripe.com/test/products
# Create one Product (e.g., "Credit pack") with three Prices: $1, $5, $10
# Copy the price_... API ID for each.
# Code accepts either spelling (singular/plural, by-credits or by-dollars)
STRIPE_PRICE_1_CREDIT=price_
STRIPE_PRICE_5_CREDITS=price_
STRIPE_PRICE_12_CREDITS=price_

# Webhook signing secret. Locally: run `stripe listen --forward-to localhost:8000/webhooks/stripe/`
# and copy the whsec_... it prints. In prod: get from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# ── Production-only (set on Vercel, not locally) ──────────
# CANONICAL_HOST=lamarca.vercel.app
